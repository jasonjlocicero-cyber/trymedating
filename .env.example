# .env.example
# Copy this file to:
#   - .env.local  (recommended for local dev)
# and fill in real values.
#
# Vite exposes ONLY VITE_* vars to the browser.
# Netlify Functions (server-side) read NON-VITE vars via process.env.

# ----------------------
# Supabase (client-side)
# ----------------------
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ----------------------
# App (client-side)
# ----------------------
VITE_APP_ENV=development
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Optional: if your client uses this to call functions
VITE_SUPA_FUNCTIONS_URL=http://localhost:8888/.netlify/functions

# Optional: Sentry (client)
VITE_SENTRY_DSN=

# ----------------------
# Push (client-side)
# ----------------------
# This is used by the browser to subscribe (applicationServerKey)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# ----------------------
# Netlify Functions (server-side)
# ----------------------
# IMPORTANT: Your function uses process.env.SUPABASE_URL and process.env.SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Push (server-side): used by netlify/functions/push-message to send web push
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@trymedating.com

# Optional: protect the push endpoint from random callers
PUSH_WEBHOOK_SECRET=YOUR_RANDOM_SECRET
