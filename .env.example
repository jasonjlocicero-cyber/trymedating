# Rename to ".env.local" locally and fill real values
# - Vite exposes ONLY VITE_* to the browser
# - Netlify Functions use NON-VITE vars (server-side only)

# =========================
# Supabase (client / Vite)
# =========================
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# App (client / Vite)
VITE_APP_ENV=development
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Push (client / Vite)
# This MUST match the VAPID_PUBLIC_KEY below (same value, different name)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# =====================================
# Netlify Functions (server-side only)
# =====================================
# These are REQUIRED for /.netlify/functions/push-message to work locally
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Web Push (server-side only)
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@trymedating.com

# Optional: protect the push endpoint from random callers
# PUSH_WEBHOOK_SECRET=YOUR_RANDOM_SECRET

# Optional: protect the push endpoint from random callers
PUSH_WEBHOOK_SECRET=YOUR_RANDOM_SECRET
