# =========================
# TryMeDating local template
# Copy this file to .env.local and fill in real values.
# Do NOT put real secrets in this file.
# =========================

# ---- Server / Netlify Functions (required for push-message local testing) ----
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@trymedating.com

# ---- Client / Vite (required for app UI + subscription registration) ----
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# ---- Optional app/local values ----
VITE_APP_ENV=development
VITE_PUBLIC_SITE_URL=http://localhost:8888
VITE_SUPA_FUNCTIONS_URL=http://localhost:8888/.netlify/functions
